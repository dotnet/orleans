<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Microsoft.Orleans.Testing.Reminders</PackageId>
    <Title>Microsoft Orleans reminders testing library</Title>
    <Description>Reminder testing utilities for Microsoft Orleans.</Description>
    <PackageTags>$(PackageTags) ReminderTestKit</PackageTags>
    <TargetFrameworks>$(DefaultTargetFrameworks)</TargetFrameworks>
    <IsOrleansFrameworkPart>false</IsOrleansFrameworkPart>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
    <PackageReference Include="System.Reactive" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(SourceRoot)src\Orleans.Reminders\Orleans.Reminders.csproj" />
    <ProjectReference Include="$(SourceRoot)src\Orleans.TestingHost\Orleans.TestingHost.csproj" />
  </ItemGroup>
</Project>
