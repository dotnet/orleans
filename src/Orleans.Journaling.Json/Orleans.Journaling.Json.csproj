<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Microsoft.Orleans.Journaling.Json</PackageId>
    <Title>Microsoft Orleans Journaling - JSON Codec</Title>
    <Description>System.Text.Json-based serialization codec for Orleans.Journaling durable state machines.</Description>
    <PackageTags>$(PackageTags) Persistence State Machines JSON</PackageTags>
    <TargetFrameworks>$(DefaultTargetFrameworks)</TargetFrameworks>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);ORLEANSEXP005</NoWarn>
    <VersionSuffix Condition="$(VersionSuffix) != ''">$(VersionSuffix).alpha.1</VersionSuffix>
    <VersionSuffix Condition="$(VersionSuffix) == ''">alpha.1</VersionSuffix>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(SourceRoot)src\Orleans.Journaling\Orleans.Journaling.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Orleans.Journaling.Tests" />
    <InternalsVisibleTo Include="Orleans.Journaling.Json.Tests" />
  </ItemGroup>

</Project>
